# Large artifacts live on Google Drive, fetched via checkpoints/download_checkpoints.py
# and scripts/download_assets.py. Keep configs / manifests / metrics in git.
checkpoints/**/*.pt
data/dexgraspdb/
data/**/*.npz
data/**/*.h5

# Run outputs
outputs/
logs/
**/events.out.tfevents*

# internal
docs/

# Python
__pycache__/
*.pyc
*.egg-info/
.eggs/
build/
dist/
.venv/
.pytest_cache/
.ruff_cache/

# Local-only alt variant (Real-NVP flow / grasp_center frame); not part of release
checkpoints/allegro_full_flow_alt/

# Local-only dev scripts (paper figures / training-curve plots / sweeps). These
# target private dataset/paper trees and are not part of the public release; kept
# here for local use only.
dev_scripts/
src/equidexflow/kinematics/seating_leap.py

# Private publication-grade renderer (house figure style). The public repo ships
# only the neutral visual-mesh viewer in equidexflow.render; this stays local.
figure_kit/

# Local-only finger-link self-collision / anti-clustering tests (not shipped).
tests/test_self_collision.py

# assets — ignore all frogger_ycb meshes except the four shipped objects
assets/objects/frogger_ycb/*
!assets/objects/frogger_ycb/005_tomato_soup_can.obj
!assets/objects/frogger_ycb/006_mustard_bottle.obj
!assets/objects/frogger_ycb/010_potted_meat_can.obj
!assets/objects/frogger_ycb/056_tennis_ball.obj